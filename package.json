{
  "name": "soundbridg-desktop",
  "version": "2.3.0",
  "description": "SoundBridg — Auto-sync FL Studio exports to the cloud",
  "main": "main.js",
  "author": "SoundBridg",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "dist": "electron-builder --mac dmg",
    "dist:universal": "electron-builder --mac dmg --universal",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.soundbridg.desktop",
    "productName": "SoundBridg",
    "copyright": "Copyright © 2026 SoundBridg",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "mac": {
      "category": "public.app-category.music",
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "identity": null
    },
    "dmg": {
      "title": "SoundBridg",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "axios": "^1.6.7",
    "chokidar": "^3.6.0",
    "electron-store": "^8.2.0",
    "form-data": "^4.0.1"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  }
}
